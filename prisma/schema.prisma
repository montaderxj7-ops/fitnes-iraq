generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role          @default(CLIENT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  clientProfile Client?
  coachProfile  CoachProfile?
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CoachProfile {
  id                    String          @id @default(cuid())
  userId                String          @unique
  slug                  String          @unique
  name                  String
  specialty             String
  bio                   String
  instagram             String
  image                 String?
  logo                  String?
  primaryColor          String          @default("#D6F854")
  appName               String          @default("Gym System")
  welcomeImage          String?
  dashboardHeroImage    String?
  dashboardHeroTopText  String?
  dashboardHeroMainText String?
  dashboardHeroBottomText String?
  dashboardLoginEnabled Boolean         @default(false)
  subscriptionTier      String          @default("pro")
  hasPaid               Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  clients               Client[]        @relation("CoachClients")
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises             Exercise[]
  packages              Package[]
  paymentMethods        PaymentMethod[]
  workoutPlans          WorkoutPlan[]
  nutritionPlans        NutritionPlan[]
  foodItems             FoodItem[]
}

model Package {
  id           String       @id @default(cuid())
  coachId      String
  name         String
  price        String
  clientsCount Int          @default(0)
  hasNutrition Boolean      @default(false)
  hasChat      Boolean      @default(true)
  chatDays     String       @default("يومياً")
  chatHours    String       @default("مفتوح")
  popular      Boolean      @default(false)
  features     String       @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  coach        CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model Client {
  id        String       @id @default(cuid())
  userId    String       @unique
  coachId   String
  name      String
  age       Int?
  weight    Float?
  height    Float?
  goal      String?
  injuries  String?
  package   String
  status    String       @default("active")
  startDate DateTime     @default(now())
  endDate   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  coach     CoachProfile @relation("CoachClients", fields: [coachId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String       @id @default(cuid())
  coachId   String
  name      String
  details   String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  coachId     String
  clientName  String
  packageName String
  amount      String
  method      String
  status      String   @default("completed")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chat {
  id          String   @id @default(cuid())
  coachId     String
  clientName  String
  lastMessage String
  time        String
  unread      Int      @default(0)
  status      String   @default("active")
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  sender    String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  coachId     String
  text        String
  time        String
  status      String   @default("info")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id               String            @id @default(cuid())
  coachId          String
  name             String
  targetMuscle     String
  mediaUrl         String?
  defaultSets      Int               @default(3)
  defaultReps      Int               @default(12)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  coach            CoachProfile      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id        String       @id @default(cuid())
  clientId  String
  coachId   String
  name      String       @default("النظام التدريبي")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  days      WorkoutDay[]
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model WorkoutDay {
  id        String            @id @default(cuid())
  planId    String
  name      String
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  plan      WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String     @id @default(cuid())
  dayId      String
  exerciseId String
  sets       Int
  reps       Int
  order      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  day        WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

enum Role {
  COACH
  CLIENT
}

model FoodItem {
  id           String         @id @default(cuid())
  coachId      String
  name         String
  calories     Float          @default(0)
  protein      Float          @default(0)
  carbs        Float          @default(0)
  fats         Float          @default(0)
  mediaUrl     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  coach        CoachProfile   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  mealFoods    MealFood[]
}

model NutritionPlan {
  id        String          @id @default(cuid())
  clientId  String
  coachId   String
  name      String          @default("النظام الغذائي")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  days      NutritionDay[]
  coach     CoachProfile    @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model NutritionDay {
  id        String          @id @default(cuid())
  planId    String
  name      String
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  plan      NutritionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  meals     NutritionMeal[]
}

model NutritionMeal {
  id        String         @id @default(cuid())
  dayId     String
  name      String
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  day       NutritionDay   @relation(fields: [dayId], references: [id], onDelete: Cascade)
  foods     MealFood[]
}

model MealFood {
  id         String         @id @default(cuid())
  mealId     String
  foodId     String
  amount     String         @default("100g")
  order      Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  meal       NutritionMeal  @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food       FoodItem       @relation(fields: [foodId], references: [id], onDelete: Cascade)
}
