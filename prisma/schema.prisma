// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Package {
  id           String   @id @default(cuid())
  name         String
  price        String
  clientsCount Int      @default(0)
  hasNutrition Boolean  @default(false)
  hasChat      Boolean  @default(true)
  chatDays     String   @default("يومياً")
  chatHours    String   @default("مفتوح")
  popular      Boolean  @default(false)
  features     String   @default("[]") // JSON stringified array
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String?
  age       Int?
  weight    Float?
  height    Float?
  goal      String?
  injuries  String?
  package   String
  status    String   @default("active") // active, pending, offline
  startDate DateTime @default(now())
  endDate   DateTime?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  clientName  String
  packageName String
  amount      String
  method      String
  status      String   @default("completed") // completed, pending
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chat {
  id          String   @id @default(cuid())
  clientName  String
  lastMessage String
  time        String
  unread      Int      @default(0)
  status      String   @default("active") // active, closed
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id           String   @id @default(cuid())
  coachName    String   @default("كابتن برو")
  coachAvatar  String?  // Base64 or URL
  appName      String   @default("Gym System")
  appLogo      String?
  primaryColor String   @default("#D6F854")
  bio                   String?
  welcomeImage          String?
  dashboardLoginEnabled Boolean  @default(false)
  dashboardEmail        String?
  dashboardPassword     String?
  subscriptionTier      String   @default("pro") // "pro" (50$) or "basic"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String
  details   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  text        String
  time        String
  status      String   @default("info") // urgent, warning, info
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id           String   @id @default(cuid())
  coachId      String   @default("default_coach")
  name         String
  targetMuscle String
  mediaUrl     String?
  defaultSets  Int      @default(3)
  defaultReps  Int      @default(12)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  clientId  String
  coachId   String   @default("default_coach")
  name      String   @default("النظام التدريبي")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  days      WorkoutDay[]
}

model WorkoutDay {
  id        String   @id @default(cuid())
  planId    String
  name      String   // e.g., "اليوم الأول" or "صدر وتراي"
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  dayId      String
  exerciseId String
  sets       Int
  reps       Int
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  day        WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  specialty     String
  bio           String
  instagram     String
  image         String?
  logo          String?
  primaryColor  String   @default("#D6F854")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  chatId    String   // could link to Chat model if needed, but keeping it simple
  sender    String   // 'coach' or 'client'
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
